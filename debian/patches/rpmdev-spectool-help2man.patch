From: KOSHIKAWA Kenichi <reishoku.misc@pm.me>
Date: 2026-01-28
Subject: rpmdev-spectool: make help2man-friendly

help2man invokes rpmdev-spectool with -v and -h. Accept -v as a version
alias and delay importing the rpm module until it is actually needed so
usage generation works in minimal build environments.

---
 rpmdev-spectool | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

--- a/rpmdev-spectool
+++ b/rpmdev-spectool
@@ -28,7 +28,6 @@ import tempfile
 import time
 from collections import OrderedDict
 from typing import Optional
 from urllib.parse import urlparse
 
 import progressbar
 import requests
-import rpm
@@ -77,6 +76,7 @@ def get_args() -> dict:
     ops.add_argument(
         "--version",
         "-V",
+        "-v",
         action="version",
         version="%(prog)s {}".format(__version__),
         help="Print the version and exit",
@@ -143,6 +143,8 @@ class Spec:
     def __init__(self, path: str):
         self.path = path
-        self.spec = rpm.spec(self.path)
+        import rpm
+
+        self.spec = rpm.spec(self.path)
@@ -404,6 +406,8 @@ def main() -> int:
         if args["directory"]:
             directory = args["directory"]
         elif args["sourcedir"]:
+            import rpm
+
             directory = rpm.expandMacro("%{_sourcedir}")
         else:
             directory = os.getcwd()
